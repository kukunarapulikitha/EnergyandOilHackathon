# Copy this file to .env and fill in your keys.
# .env is gitignored — never commit real keys.

# ── Data source (required) ──────────────────────────────────────────────────
# Free key: https://www.eia.gov/opendata/register.php
EIA_API_KEY=your_eia_api_key_here

# ── AI providers (at least one required for AI Analyst tab) ─────────────────
# The app tries each in order: Groq → xAI → Gemini
# Set whichever keys you have; missing keys are skipped automatically.

# Groq — Llama 3.3 70B (recommended, fastest, free tier)
# Register: https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# xAI — Grok 2 (fallback)
# Register: https://console.x.ai
XAI_API_KEY=your_xai_api_key_here

# Google Gemini — Gemini 1.5 Flash (last resort)
# Register: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
